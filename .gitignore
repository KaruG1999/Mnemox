# Binary output — /mnemox anchors to root only, so cmd/mnemox/ is not excluded
/mnemox
bin/

# SQLite database and WAL auxiliary files
*.db
*.db-wal
*.db-shm

# Environment — never commit real credentials
.env

# Node / frontend
node_modules/
dist/
out/

# SDK pre-built artifacts must be committed so judges can npm install ./ui/sdk directly.
# The root `dist/` rule above ignores all other dist/ dirs (Remotion, etc.).
!ui/sdk/dist/
!ui/sdk/dist/**

# Go build cache (local artifacts)
*.test
*.out
