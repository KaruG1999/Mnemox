# ─── Stellar Network ──────────────────────────────────────────────────────────

# Testnet (default — hackathon / development)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Mainnet — uncomment and replace with your provider API key
# STELLAR_RPC_URL=https://mainnet.stellar.validationcloud.io/v1/<API_KEY>
# STELLAR_RPC_URL=https://soroban-rpc.stellar.org  # public, rate-limited

# ─── Contract ─────────────────────────────────────────────────────────────────

# Required. The Soroban contract address emitting new_commitment_event.
CONTRACT_ID=

# CRITICAL FOR MAINNET: set this to the exact ledger sequence number of the
# contract deployment transaction. Any value higher than the deployment ledger
# will cause Mnemox to miss early commitment events, producing a permanent
# Merkle root mismatch that breaks all ZK proofs retroactively.
#
# Find the deployment ledger on Stellar Expert:
#   https://stellar.expert/explorer/mainnet/contract/<CONTRACT_ID>
#
# Setting START_LEDGER=0 anchors to the RPC node's oldest retained ledger
# (~7 days back). Safe for new contracts; dangerous for contracts older than
# 7 days — those early events are unrecoverable from RPC.
START_LEDGER=0

# ─── Storage ──────────────────────────────────────────────────────────────────

# Path to the SQLite WAL database file.
# PRODUCTION: point this to a persistent volume mount so the file survives
# container restarts and redeployments.
#   Render / Railway:  /data/mnemox.db   (mount a Persistent Disk at /data)
#   VPS:               /var/lib/mnemox/mnemox.db
#
# Growth rate: ~120 bytes per indexed event (64-byte hex commitment +
# ledger/contract/timestamp metadata). 10 GB supports ~83 million events.
DB_PATH=./mnemox.db

# ─── API Server ───────────────────────────────────────────────────────────────

API_PORT=8080

# ─── Streamer ─────────────────────────────────────────────────────────────────

# Polling interval in milliseconds. Soroban closes a ledger every ~5 seconds.
# Values below 2000 provide no benefit and increase RPC load.
POLL_INTERVAL_MS=5000

# ─── Metadata ─────────────────────────────────────────────────────────────────

# Reported in the /health response. Switch to "mainnet" for production.
NETWORK=testnet
